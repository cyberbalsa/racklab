{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "racklab/plugin-hello",
    "type": "library",
    "description": "Reference plugin for RackLab plugin lifecycle and contract tests.",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Racklab\\PluginHello\\": "src/"
        }
    },
    "extra": {
        "racklab": {
            "plugin": true,
            "slug": "racklab/plugin-hello"
        },
        "laravel": {
            "dont-discover": [
                "racklab/plugin-hello"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
