{
    "$schema": "https://getcomposer.org/schema.json",
    "name": "racklab/console-proxmox",
    "type": "library",
    "description": "RackLab Proxmox console capability plugin (console:proxmox:v1).",
    "license": "Apache-2.0",
    "require": {
        "php": "^8.3",
        "illuminate/support": "^13.0"
    },
    "autoload": {
        "psr-4": {
            "Racklab\\ConsoleProxmox\\": "src/"
        }
    },
    "extra": {
        "racklab": {
            "plugin": true,
            "slug": "racklab/console-proxmox",
            "capabilities": [
                "console:proxmox:v1"
            ]
        },
        "laravel": {
            "dont-discover": [
                "racklab/console-proxmox"
            ]
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
